# Copia este archivo como .env y rellena los valores reales.
# El .env NO se sube a GitHub (está en .gitignore).

# Obligatoria — tu API key de fal.ai
FAL_KEY=tu_api_key_de_fal_aqui

# Opcionales — solo si quieres estadísticas en Supabase
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu_service_role_key_de_supabase
